{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm install",
  "installCommand": "npm install",
  "outputDirectory": "src/public",
  "regions": ["sin1"],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}